DATABASE_URL=postgres://localhost:5432/hledsluverd
DATABASE_URL_TEST=postgres://localhost:5432/hledsluverd_test
OCM_API_KEY=
NTFY_TOPIC=
TOMTOM_API_KEY=

# --- Production only (see docs/deploy.md) -----------------------------------
# In production, .env is read BOTH by dotenv (tsx scripts) and by systemd
# EnvironmentFile= — keep it to plain KEY=value lines: no `export`, no quotes,
# no $VAR expansion, no `#` or spaces inside values (hex secrets via
# `openssl rand -hex 24`).
# ORIGIN=https://hledsluverd.is
# HOST=127.0.0.1
# PORT=3000
# HEALTHCHECKS_URL=https://hc-ping.com/<uuid-of-the-scrape-check>
# HEALTHCHECKS_BACKUP_URL=https://hc-ping.com/<uuid-of-the-backup-check>
