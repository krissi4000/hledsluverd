{
	"name": "hledsluverd",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"db:migrate": "drizzle-kit migrate",
		"seed:networks": "tsx scripts/seed-networks.ts",
		"seed:ocm": "tsx scripts/seed-ocm.ts",
		"seed:prices": "tsx scripts/seed-prices.ts",
		"scrape": "tsx scripts/scrape.ts",
		"match:virta": "tsx scripts/match-virta.ts",
		"match:n1": "tsx scripts/match-n1.ts"
	},
	"devDependencies": {
		"@inlang/paraglide-js": "^2.20.2",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^26.1.0",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.10",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tsx": "^4.22.5",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"chart.js": "^4.5.1",
		"cheerio": "^1.2.0",
		"drizzle-orm": "^0.45.2",
		"playwright": "^1.61.1",
		"postgres": "^3.4.9"
	}
}
